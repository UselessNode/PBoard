<Window x:Class="PBoard.Views.TextStyleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBoard.Views"
        mc:Ignorable="d"
        Title="Настройка оформления текста" Height="Auto" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Параметры оформления текстового блока" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <!-- Основное содержимое -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Левая панель настроек -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,10,0">
                    <!-- Предустановленные стили -->
                    <GroupBox Header="Предустановки" Margin="0,0,0,10">
                        <ListBox x:Name="StylePresets" Height="80" SelectionChanged="StylePresets_SelectionChanged">
                            <ListBoxItem Content="Стандартный"/>
                            <ListBoxItem Content="Заметка"/>
                            <ListBoxItem Content="Важное"/>
                            <ListBoxItem Content="Информация"/>
                            <ListBoxItem Content="Код"/>
                        </ListBox>
                    </GroupBox>
                    
                    <!-- Цвета -->
                    <GroupBox Header="Цвета" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Цвет фона -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Фон:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Button Grid.Row="0" Grid.Column="1" Height="24" Click="BackgroundColor_Click" Margin="0,5,0,5">
                                <Button.Background>
                                    <SolidColorBrush Color="{Binding BackgroundColor}"/>
                                </Button.Background>
                            </Button>
                            
                            <!-- Цвет текста -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Текст:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Button Grid.Row="1" Grid.Column="1" Height="24" Click="TextColor_Click" Margin="0,5,0,5">
                                <Button.Background>
                                    <SolidColorBrush Color="{Binding TextColor}"/>
                                </Button.Background>
                            </Button>
                            
                            <!-- Цвет границы -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Граница:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Button Grid.Row="2" Grid.Column="1" Height="24" Click="BorderColor_Click" Margin="0,5,0,5">
                                <Button.Background>
                                    <SolidColorBrush Color="{Binding BorderColor}"/>
                                </Button.Background>
                            </Button>
                        </Grid>
                    </GroupBox>
                    
                    <!-- Параметры границы -->
                    <GroupBox Header="Граница" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Толщина границы -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Толщина:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="BorderThicknessSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="10" Value="1" 
                                    TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="BorderThicknessSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding ElementName=BorderThicknessSlider, Path=Value, StringFormat={}{0:F1}}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            
                            <!-- Радиус скругления -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Скругление:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="CornerRadiusSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="30" Value="2" 
                                    ValueChanged="CornerRadiusSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding ElementName=CornerRadiusSlider, Path=Value, StringFormat={}{0:F1}}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </GroupBox>
                    
                    <!-- Параметры шрифта -->
                    <GroupBox Header="Шрифт" Margin="0,0,0,10">
                        <StackPanel Orientation="Vertical">
                            <ComboBox
                                ItemsSource="{x:Static Fonts.SystemFontFamilies}"
                                SelectedItem="{Binding FontFamily, Mode=TwoWay}"
                                >

                            </ComboBox>
                            
                            
                            <Grid> <!-- Размер шрифта -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Размер:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                                <Slider Grid.Column="1" x:Name="FontSizeSlider" Minimum="8" Maximum="128" 
                                    Value="14" ValueChanged="FontSizeSlider_ValueChanged" Margin="0,5,10,5"/>
                                <TextBox Grid.Column="2" Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F1}}"
                                     VerticalAlignment="Center" HorizontalAlignment="Left"/>

                            </Grid>


                            
                            <GroupBox Header="Стиль:"> <!-- Стиль шрифта -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                    <CheckBox x:Name="BoldCheckbox" Content="Жирный" 
                                              Margin="0,0,10,0" Checked="FontStyle_Changed" Unchecked="FontStyle_Changed"/>
                                    <CheckBox x:Name="ItalicCheckbox" Content="Курсив" 
                                              Margin="0,0,10,0" Checked="FontStyle_Changed" Unchecked="FontStyle_Changed"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                        
                </StackPanel>
            </ScrollViewer>
            
            <!-- Правая панель предпросмотра -->
            <GroupBox Grid.Column="1" Header="Предпросмотр">
                <Border x:Name="PreviewBorder" Background="{Binding BackgroundBrush}" 
                            BorderBrush="{Binding BorderBrush}" 
                            BorderThickness="{Binding BorderThickness}" 
                            CornerRadius="{Binding CornerRadius}" Margin="10">
                    <TextBlock x:Name="PreviewText" Text="Пример текста&#10;для предпросмотра&#10;оформления" TextWrapping="Wrap" 
                                   Foreground="{Binding ForegroundBrush}" 
                                   FontSize="{Binding FontSize}" 
                                   FontWeight="{Binding FontWeight}"
                                   FontStyle="{Binding FontStyle}"
                                   FontFamily="{Binding FontFamily}"
                                   Margin="10" TextAlignment="Left" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </GroupBox>
        </Grid>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OKButton" Content="OK" Width="80" Height="30" Margin="0,0,10,0" Click="OKButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window> 