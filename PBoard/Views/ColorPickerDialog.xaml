<Window x:Class="PBoard.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBoard.Views"
        mc:Ignorable="d"
        Title="Выбор цвета" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Выберите цвет" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <!-- Цветовая панель -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Основная палитра цветов -->
            <TabControl Grid.Column="0" Margin="0,0,10,0">
                <TabItem Header="Стандартные">
                    <ItemsControl x:Name="StandardColors" Margin="5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="8" Rows="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="28" Height="28" Margin="2" 
                                        Background="{Binding}" 
                                        Click="ColorButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border BorderBrush="Black" BorderThickness="1" Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </TabItem>
                <TabItem Header="Расширенные">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- RGB слайдеры -->
                        <Grid Grid.Row="0" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Красный -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="RedSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" 
                                    Value="{Binding Red}" ValueChanged="RgbSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding ElementName=RedSlider, Path=Value, StringFormat={}{0:F0}}" 
                                     VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            
                            <!-- Зеленый -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="GreenSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" 
                                    Value="{Binding Green}" ValueChanged="RgbSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding ElementName=GreenSlider, Path=Value, StringFormat={}{0:F0}}" 
                                     VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            
                            <!-- Синий -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="BlueSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" 
                                    Value="{Binding Blue}" ValueChanged="RgbSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding ElementName=BlueSlider, Path=Value, StringFormat={}{0:F0}}" 
                                     VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            
                            <!-- Прозрачность -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="A:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                            <Slider x:Name="AlphaSlider" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" 
                                    Value="{Binding Alpha}" ValueChanged="RgbSlider_ValueChanged" Margin="0,5,10,5"/>
                            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding ElementName=AlphaSlider, Path=Value, StringFormat={}{0:F0}}" 
                                     VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Код цвета -->
                        <Grid Grid.Row="1" Margin="10,0,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Код цвета:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" x:Name="HexColorTextBox" Text="{Binding HexColor, UpdateSourceTrigger=PropertyChanged}" 
                                     TextChanged="HexColorTextBox_TextChanged"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
            
            <!-- Предпросмотр выбранного цвета -->
            <Grid Grid.Column="1" Width="120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Текущий цвет:" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border Grid.Row="1" x:Name="SelectedColorPreview" BorderBrush="Black" BorderThickness="1" Background="{Binding SelectedColorBrush}">
                    <TextBlock Text="{Binding HexColor}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="{Binding ContrastTextBrush}"/>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Недавно использованные цвета -->
        <GroupBox Grid.Row="2" Header="Недавно использованные" Margin="0,10,0,10">
            <ItemsControl x:Name="RecentColors" Margin="5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="28" Height="28" Margin="2" 
                                Background="{Binding}" 
                                Click="ColorButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="Black" BorderThickness="1" Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </GroupBox>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button x:Name="OKButton" Content="OK" Width="80" Height="30" Margin="0,0,10,0" Click="OKButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window> 