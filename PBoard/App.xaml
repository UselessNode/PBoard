<Application x:Class="PBoard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PBoard"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Icons.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Глобальные цвета приложения -->
            <SolidColorBrush x:Key="PrimaryColor" Color="#2196F3"/>
            <SolidColorBrush x:Key="PrimaryLightColor" Color="#BBDEFB"/>
            <SolidColorBrush x:Key="PrimaryDarkColor" Color="#1976D2"/>
            <SolidColorBrush x:Key="AccentColor" Color="#FF5722"/>
            <SolidColorBrush x:Key="TextColor" Color="#212121"/>
            <SolidColorBrush x:Key="LightTextColor" Color="#757575"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
