<Window x:Class="PBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PBoard"
        mc:Ignorable="d"
        Background="#EBF5FE"
        Title="PBoard - Интерактивная доска" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Дополнительные стили, специфичные для MainWindow -->
        <Style x:Key="ToolBarStyle" TargetType="ToolBar">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource ToolBarStyle}">
            <!-- Инструменты (радиокнопки) -->
            <RadioButton x:Name="SelectionTool" 
                         GroupName="Tools" 
                         Content="Выделение" 
                         IsChecked="True" 
                         ToolTip="Выбор и перемещение элементов"
                         Style="{StaticResource ToolButtonStyle}"
                         Tag="{StaticResource SelectionIcon}"/>
                         
            <RadioButton x:Name="RichTextTool" 
                         GroupName="Tools" 
                         Content="Текст" 
                         ToolTip="Добавить форматированный текстовый блок"
                         Style="{StaticResource ToolButtonStyle}"
                         Tag="{StaticResource TextIcon}"/>

            <RadioButton x:Name="ImageTool" 
                         GroupName="Tools" 
                         Content="Изображение" 
                         ToolTip="Вставить изображение из файла"
                         Style="{StaticResource ToolButtonStyle}"
                         Tag="{StaticResource ImageIcon}"/>
            <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>
            
            <!-- Кнопки действий -->
            <Button x:Name="UndoButton"
                    Width="34"
                    ToolTip="Отменить последнее действие"
                    Style="{StaticResource ActionButtonStyle}"
                    Tag="{StaticResource UndoIcon}"/>
                    
            <Button x:Name="RedoButton"
                    Width="34"
                    ToolTip="Вернуть отмененное действие"
                    Style="{StaticResource ActionButtonStyle}"
                    Tag="{StaticResource RedoIcon}"/>
                    
            <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>
            
            <Button x:Name="ExportButton" 
                    Content="Экспорт" 
                    ToolTip="Экспортировать проект в файл"
                    Style="{StaticResource ActionButtonStyle}"
                    Tag="{StaticResource ExportIcon}"/>
                    
            <Button x:Name="ImportButton" 
                    Content="Импорт" 
                    ToolTip="Импортировать проект из файла"
                    Style="{StaticResource ActionButtonStyle}"
                    Tag="{StaticResource ImportIcon}"/>
        </ToolBar>
        
        <StatusBar DockPanel.Dock="Bottom" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource LightTextColor}">Готово</TextBlock>
            </StatusBarItem>
        </StatusBar>
        
        <Border Style="{StaticResource WorkAreaStyle}">
            <Grid>
                <ScrollViewer x:Name="WorkAreaScroll" 
                              Background="#444444"
                              HorizontalScrollBarVisibility="Auto" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="WorkArea" 
                            Background="White" 
                            Width="2000" 
                            Height="2000" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MouseDown="WorkArea_MouseDown" 
                            MouseMove="WorkArea_MouseMove" 
                            MouseUp="WorkArea_MouseUp">

                        <!-- Прямоугольник выделения -->
                        <Rectangle x:Name="SelectionRectangle" 
                                   Stroke="{StaticResource PrimaryColor}" 
                                   StrokeThickness="1" 
                                   StrokeDashArray="2,2" 
                                   Fill="{StaticResource PrimaryLightColor}" 
                                   Opacity="0.3" 
                                   Visibility="Collapsed" 
                                   Canvas.ZIndex="1000" />
                    </Canvas>
                </ScrollViewer>
            </Grid>
        </Border>
    </DockPanel>
</Window>
